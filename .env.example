PORT=3000
NODE_ENV=development
# Postgres bağlantı adresi. Örnek (Neon): postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/facechat?sslmode=require
DATABASE_URL=
# Bulut Postgres için true; kendi lokal Postgres'inde false.
DB_SSL=true
# Upstash Redis adresi. Örnek: rediss://default:xxxx@eu1-xxx.upstash.io:6379
REDIS_URL=
# Supabase Auth (Settings → API):
SUPABASE_URL=
SUPABASE_ANON_KEY=
# TURN (medya relay). Örnek: TURN_URLS=turn:xxx.metered.live:80,turns:xxx.metered.live:443
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
# IP hash tuzu — üretimde güçlü rastgele bir değer (openssl rand -hex 32):
IP_HASH_SALT=
# CORS izinli origin'ler (virgülle). Boş = herkese izin. Örn: https://web.faceha.com
CORS_ORIGINS=
# Admin moderasyon API token'ı (openssl rand -hex 32):
ADMIN_TOKEN=
MODERATION_PROVIDER=none
MODERATION_API_KEY=
AUTO_BAN_FIRST_DURATION_MINUTES=60
REPORT_THRESHOLD_24H=3
# Play Console servis hesabı (kurulunca doldurulacak — boşken premium doğrulaması reddeder):
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=
